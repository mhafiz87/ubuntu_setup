# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000
bindkey -v

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Clone zsh-autosuggestion if yet to clone
if [[ ! -d "$HOME/.config/zsh/zsh-autosuggestions" ]]; then
    git clone https://github.com/zsh-users/zsh-autosuggestions.git --depth 1 $HOME/.config/zsh/zsh-autosuggestions
fi
source ~/.config/zsh/zsh-autosuggestions/zsh-autosuggestions.zsh

# Clone zsh-syntax-highlighting if yet to clone
if [[ ! -d "$HOME/.config/zsh/zsh-autosuggestions" ]]; then
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git --depth 1 $HOME/.config/zsh/zsh-syntax-highlighting
fi
source ~/.config/zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Clone zsh-completions if yet to clone
if [[ ! -d "$HOME/.config/zsh/zsh-completions" ]]; then
    git clone https://github.com/zsh-users/zsh-completions.git --depth 1 $HOME/.config/zsh/zsh-completions
fi
fpath=(~/.zsh/zsh-completions/src $fpath)
autoload -Uz compinit && compinit

eval "$(starship init zsh)"
