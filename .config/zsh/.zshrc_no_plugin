# -----------------------------
# History
# -----------------------------
HISTFILE="$HOME/.histfile"
HISTSIZE=10000
SAVEHIST=10000

setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
setopt INTERACTIVE_COMMENTS

# -----------------------------
# Environment
# -----------------------------
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# -----------------------------
# Aliases
# -----------------------------
alias ll='ls -lahF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'
alias bat='batcat'
alias fd='fdfind'

# -----------------------------
# FZF
# -----------------------------
export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fdfind --type d --hidden --follow --exclude .git'

export FZF_DEFAULT_OPTS="
  --height 40%
  --layout=reverse
  --border
  --inline-info
  --cycle
"

# Use bat for preview if available
export FZF_CTRL_T_OPTS="
  --preview 'batcat --style=numbers --color=always --line-range :500 {} 2>/dev/null || cat {}'
  --preview-window=right:60%:wrap
"

export FZF_ALT_C_OPTS="
  --preview 'tree -C {} | head -200'
"

[ -f "$HOME/.fzf.zsh" ] && source "$HOME/.fzf.zsh"

# -----------------------------
# Completion
# -----------------------------
ZSH_PLUGIN_DIR="$HOME/.config/zsh"

fpath=("$ZSH_PLUGIN_DIR/zsh-completions/src" $fpath)

autoload -Uz compinit
compinit -C

# -----------------------------
# Starship prompt
# -----------------------------
if [[ "${widgets[zle-keymap-select]#user:}" == "starship_zle-keymap-select" || \
      "${widgets[zle-keymap-select]#user:}" == "starship_zle-keymap-select-wrapped" ]]; then
    zle -N zle-keymap-select "";
fi

eval "$(starship init zsh)"

# -----------------------------
# zsh-vi-mode
# -----------------------------
ZVM_VI_INSERT_ESCAPE_BINDKEY=jk
ZVM_VI_VISUAL_ESCAPE_BINDKEY=jk

# [ -f "$ZSH_PLUGIN_DIR/zsh-vi-mode/zsh-vi-mode.plugin.zsh" ] && \
#   source "$ZSH_PLUGIN_DIR/zsh-vi-mode/zsh-vi-mode.plugin.zsh"

# -----------------------------
# zsh-autosuggestions
# -----------------------------
[ -f "$ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh" ] && \
  source "$ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh"

# -----------------------------
# zsh-syntax-highlighting
# Must be last
# -----------------------------
[ -f "$ZSH_PLUGIN_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ] && \
  source "$ZSH_PLUGIN_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
